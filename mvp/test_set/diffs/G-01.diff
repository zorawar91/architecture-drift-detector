--- a/packages/backend-defaults/src/entrypoints/discovery/proxyFetch.ts
+++ b/packages/backend-defaults/src/entrypoints/discovery/proxyFetch.ts
@@ -0,0 +1,10 @@
+import fetch from 'node-fetch';
+import { HttpsProxyAgent } from 'https-proxy-agent';
+
+// Native fetch (undici) does not honor HTTPS_PROXY agents for this call path.
+// See issue #24988. Scoped to discovery only; remove when undici supports it.
+export const proxyFetch = (url: string) =>
+  fetch(url, { agent: new HttpsProxyAgent(process.env.HTTPS_PROXY!) });
