--- a/plugins/announcements-backend/src/service/AnnouncementsClient.ts
+++ b/plugins/announcements-backend/src/service/AnnouncementsClient.ts
@@ -0,0 +1,14 @@
+import { ResponseError } from '@backstage/errors';
+
+export class AnnouncementsClient {
+  constructor(private readonly baseUrl: string) {}
+
+  async list() {
+    const response = await fetch(`${this.baseUrl}/announcements`);
+    if (!response.ok) {
+      throw await ResponseError.fromResponse(response);
+    }
+    return await response.json();
+  }
+}
diff --git a/plugins/announcements-backend/src/service/AnnouncementsClient.test.ts b/plugins/announcements-backend/src/service/AnnouncementsClient.test.ts
