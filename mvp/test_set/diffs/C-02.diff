@@ -0,0 +1,16 @@
+import { setupServer } from 'msw/node';
+import { rest } from 'msw';
+import { AnnouncementsClient } from './AnnouncementsClient';
+
+const server = setupServer(
+  rest.get('http://localhost/announcements', (_, res, ctx) =>
+    res(ctx.json([{ id: '1', title: 'Hello' }])),
+  ),
+);
+
+beforeAll(() => server.listen());
+afterAll(() => server.close());
+
+it('lists announcements', async () => {
+  const client = new AnnouncementsClient('http://localhost');
+  await expect(client.list()).resolves.toHaveLength(1);
+});
