+import React from 'react';
+import { DateTime } from 'luxon';
+import { InfoCard } from '@backstage/core-components';
+
+type AnnouncementCardProps = {
+  title: string;
+  publishedAt: string;
+};
+
+export const AnnouncementCard = ({ title, publishedAt }: AnnouncementCardProps) => {
+  const published = DateTime.fromISO(publishedAt).toRelative();
+  return (
+    <InfoCard title={title}>
+      <span>{published}</span>
+    </InfoCard>
+  );
+};
